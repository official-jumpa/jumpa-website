# Atlas "mongodb+srv://..." (SRV). If you get querySrv ECONNREFUSED, use the standard driver string below instead.
MONGO_URI=
# Optional: Atlas "mongodb://host1:27017,host2:27017/..." — no SRV lookup; same user/password as srv string
MONGO_URI_DIRECT=

ANTHROPIC_API_KEY=
# Auth & Sessions
AUTH_SECRET=
AUTH_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

RESEND_API_KEY=
RESEND_FROM_EMAIL="Jumpa <onboarding@jumpa.xyz>"